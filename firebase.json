{
  "hosting": {
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.md",
        "headers": [
          { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
          { "key": "X-Robots-Tag", "value": "all" }
        ]
      },
      {
        "source": "llms*.txt",
        "headers": [
          { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
          { "key": "X-Robots-Tag", "value": "all" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
